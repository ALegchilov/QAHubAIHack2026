{
  "name": "inventree-api-tests",
  "version": "1.0.0",
  "description": "Playwright API test automation for InvenTree Parts module",
  "scripts": {
    "test": "npx playwright test",
    "test:api": "npx playwright test --project=api-tests",
    "test:api:parts": "npx playwright test automation/api/parts/",
    "test:api:categories": "npx playwright test automation/api/categories/",
    "test:api:cross-cutting": "npx playwright test automation/api/cross-cutting/",
    "test:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0"
  }
}
