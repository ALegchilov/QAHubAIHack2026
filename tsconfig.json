{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@fixtures/*": ["automation/api/fixtures/*"],
      "@helpers/*": ["automation/api/helpers/*"]
    }
  },
  "include": ["automation/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
