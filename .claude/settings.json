{
  "agent": "orchestrator",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-test-case-written.sh"
          }
        ]
      }
    ]
  }
}
